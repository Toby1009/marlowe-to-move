<?xml version='1.0' encoding='utf-8'?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_MarloweBPMN" targetNamespace="https://marlowe-to-move.local/bpmn">
  <bpmn:process id="Process_MarloweContract" name="simple-voting.marlowe" isExecutable="false">
    <bpmn:documentation>Deterministic BPMN projection of a Marlowe contract. Gateway labels and event names preserve the original Marlowe semantics.</bpmn:documentation>
    <bpmn:laneSet id="LaneSet_1">
      <bpmn:lane id="Lane_1" name="Contract">
        <bpmn:flowNodeRef>endEvent_5</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>exclusiveGateway_4</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>startEvent_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>eventBasedGateway_2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>endEvent_6</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>intermediateCatchEvent_7</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>endEvent_8</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_2" name="Voter">
        <bpmn:flowNodeRef>receiveTask_3</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="startEvent_1" name="Contract start">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:eventBasedGateway id="eventBasedGateway_2" name="Await action before 2026-04-02T23:59:59Z" gatewayDirection="Diverging">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
      <bpmn:documentation>Marlowe When with 1 case(s) and timeout 2026-04-02T23:59:59Z</bpmn:documentation>
    </bpmn:eventBasedGateway>
    <bpmn:receiveTask id="receiveTask_3" name="Receive choice vote_result from Voter [0..1]">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
      <bpmn:documentation>choice_owner=Voter</bpmn:documentation>
    </bpmn:receiveTask>
    <bpmn:exclusiveGateway id="exclusiveGateway_4" name="If choice(vote_result) = 1" gatewayDirection="Diverging" default="Flow_5">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
      <bpmn:documentation>choice(vote_result) = 1</bpmn:documentation>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="endEvent_5" name="Close">
      <bpmn:incoming>Flow_4</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="endEvent_6" name="Close">
      <bpmn:incoming>Flow_5</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:intermediateCatchEvent id="intermediateCatchEvent_7" name="Timeout at 2026-04-02T23:59:59Z">
      <bpmn:incoming>Flow_6</bpmn:incoming>
      <bpmn:outgoing>Flow_7</bpmn:outgoing>
      <bpmn:documentation>Marlowe timeout branch for UNIX timestamp 1775174399</bpmn:documentation>
      <bpmn:timerEventDefinition>
        <bpmn:timeDate>2026-04-02T23:59:59Z</bpmn:timeDate>
      </bpmn:timerEventDefinition>
    </bpmn:intermediateCatchEvent>
    <bpmn:endEvent id="endEvent_8" name="Close">
      <bpmn:incoming>Flow_7</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_1" sourceRef="startEvent_1" targetRef="eventBasedGateway_2" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="eventBasedGateway_2" targetRef="receiveTask_3" name="choice by Voter" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="receiveTask_3" targetRef="exclusiveGateway_4" />
    <bpmn:sequenceFlow id="Flow_4" sourceRef="exclusiveGateway_4" targetRef="endEvent_5" name="then">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">choice(vote_result) = 1</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_5" sourceRef="exclusiveGateway_4" targetRef="endEvent_6" name="else">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">not (choice(vote_result) = 1)</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_6" sourceRef="eventBasedGateway_2" targetRef="intermediateCatchEvent_7" name="timeout" />
    <bpmn:sequenceFlow id="Flow_7" sourceRef="intermediateCatchEvent_7" targetRef="endEvent_8" />
  </bpmn:process>
  <bpmn:collaboration id="Collaboration_MarloweContract">
    <bpmn:participant id="Participant_MarloweContract" name="simple-voting.marlowe" processRef="Process_MarloweContract" />
  </bpmn:collaboration>
  <bpmndi:BPMNDiagram id="BPMNDiagram_MarloweContract">
    <bpmndi:BPMNPlane id="BPMNPlane_MarloweContract" bpmnElement="Collaboration_MarloweContract">
      <bpmndi:BPMNShape id="Participant_MarloweContract_di" bpmnElement="Participant_MarloweContract" isHorizontal="true">
        <dc:Bounds x="40" y="40" width="1036" height="420" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_1_di" bpmnElement="Lane_1" isHorizontal="true">
        <dc:Bounds x="40" y="40" width="1036" height="240" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_2_di" bpmnElement="Lane_2" isHorizontal="true">
        <dc:Bounds x="40" y="280" width="1036" height="180" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="startEvent_1_di" bpmnElement="startEvent_1">
        <dc:Bounds x="200" y="190" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="eventBasedGateway_2_di" bpmnElement="eventBasedGateway_2">
        <dc:Bounds x="340" y="190" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="receiveTask_3_di" bpmnElement="receiveTask_3">
        <dc:Bounds x="560" y="320" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="exclusiveGateway_4_di" bpmnElement="exclusiveGateway_4">
        <dc:Bounds x="780" y="80" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="endEvent_5_di" bpmnElement="endEvent_5">
        <dc:Bounds x="1000" y="80" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="endEvent_6_di" bpmnElement="endEvent_6">
        <dc:Bounds x="1000" y="190" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="intermediateCatchEvent_7_di" bpmnElement="intermediateCatchEvent_7">
        <dc:Bounds x="560" y="190" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="endEvent_8_di" bpmnElement="endEvent_8">
        <dc:Bounds x="780" y="190" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="236" y="208" />
        <di:waypoint x="288" y="208" />
        <di:waypoint x="288" y="215" />
        <di:waypoint x="340" y="215" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="390" y="215" />
        <di:waypoint x="475" y="215" />
        <di:waypoint x="475" y="360" />
        <di:waypoint x="560" y="360" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_3_di" bpmnElement="Flow_3">
        <di:waypoint x="680" y="360" />
        <di:waypoint x="730" y="360" />
        <di:waypoint x="730" y="105" />
        <di:waypoint x="780" y="105" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_4_di" bpmnElement="Flow_4">
        <di:waypoint x="830" y="105" />
        <di:waypoint x="915" y="105" />
        <di:waypoint x="915" y="98" />
        <di:waypoint x="1000" y="98" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_5_di" bpmnElement="Flow_5">
        <di:waypoint x="830" y="105" />
        <di:waypoint x="915" y="105" />
        <di:waypoint x="915" y="208" />
        <di:waypoint x="1000" y="208" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_6_di" bpmnElement="Flow_6">
        <di:waypoint x="390" y="215" />
        <di:waypoint x="475" y="215" />
        <di:waypoint x="475" y="208" />
        <di:waypoint x="560" y="208" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_7_di" bpmnElement="Flow_7">
        <di:waypoint x="596" y="208" />
        <di:waypoint x="780" y="208" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>